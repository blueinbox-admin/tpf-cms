---
interface Props {
  interviews: any[];
}

const { interviews } = Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "long", year: "numeric" });
---

<ul class="grid gap-8 md:grid-cols-2">
  {interviews.map((interview) => (
    <li>
      <a
        href={`/interviews/${interview.id}/`}
        class="group block bg-white border border-slate-200 hover:border-navy transition-colors overflow-hidden"
      >
        <div class="aspect-[4/3] overflow-hidden bg-slate-100">
          <img
            src={interview.data.portrait}
            alt={`Portrait of ${interview.data.name}`}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        </div>
        <div class="p-5">
          <p class="text-xs uppercase tracking-wider text-gold font-semibold">
            {formatDate(new Date(interview.data.publishedAt))}
          </p>
          <h2 class="mt-2 text-xl md:text-2xl font-medium text-navy">
            {interview.data.name}
          </h2>
          {interview.data.excerpt && (
            <p class="mt-2 text-sm md:text-base text-slate-600 line-clamp-3">
              {interview.data.excerpt}
            </p>
          )}
          <p class="mt-4 text-sm font-semibold text-navy group-hover:text-gold transition-colors">
            Read interview →
          </p>
        </div>
      </a>
    </li>
  ))}
</ul>
