---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import InterviewGrid from "../components/InterviewGrid.astro";
import { groupByYearWindow } from "../lib/content";

const all = (await getCollection("interviews")).sort(
  (a, b) =>
    new Date(b.data.publishedAt).getTime() -
    new Date(a.data.publishedAt).getTime()
);

const windows = groupByYearWindow(all, new Date());
const current = windows[0];
const hasOlder = windows.length > 1;
---

<BaseLayout
  title="Student Interviews — The Podcast Fellowship"
  description="Long-form interviews with students of The Podcast Fellowship."
>
  <div class="mx-auto max-w-4xl px-6 py-10 md:py-16">
    <header>
      <h1 class="text-4xl md:text-5xl font-medium text-navy tracking-tight">
        Student Interviews
      </h1>
      <div class="mt-2 h-1 w-24 bg-gold-soft"></div>
      <p class="mt-6 text-base md:text-lg text-slate-600 max-w-2xl">
        Long-form conversations with students of The Podcast Fellowship — on
        Jewish identity, learning, and the people who shaped their journey.
      </p>
    </header>

    <section class="mt-12 md:mt-16">
      {current ? (
        <InterviewGrid interviews={current.items} />
      ) : (
        <p class="text-slate-500 text-center py-12">
          No interviews published yet. Check back soon.
        </p>
      )}

      {hasOlder && (
        <div class="mt-12 md:mt-16 text-center">
          <a
            href="/archive/2/"
            class="inline-block border border-navy text-navy hover:bg-navy hover:text-white transition-colors font-semibold px-8 py-3 rounded-sm"
          >
            Previous interviews →
          </a>
        </div>
      )}
    </section>

    <footer class="mt-20 pt-10 border-t border-slate-200 text-center text-sm text-slate-500">
      <p>
        The Podcast Fellowship —{" "}
        <a
          href="https://podcastfellowship.org/"
          class="text-navy hover:text-gold transition-colors"
        >
          podcastfellowship.org
        </a>
      </p>
    </footer>
  </div>
</BaseLayout>
